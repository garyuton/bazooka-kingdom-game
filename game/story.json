      "characters": [],
      "speaker": "ガリュ㌧",
      "hideName": false,
      "text": "「少年が目を覚ましたのは、城の下男宿舎じゃった。」",
      "se": null,
      "choices": null
    },
    {
      "id": "scene3-02",
